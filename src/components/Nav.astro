---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/taste/', label: 'A Taste of the Book' },
  { href: '/farm-shop/', label: 'Farm Shop' },
  { href: '/illustrations/', label: 'Illustrations' },
  { href: '/contact/', label: 'Contact' },
];
---

<nav class="bg-white border-b border-border sticky top-0 z-50">
  <div class="max-w-4xl mx-auto px-4">
    <!-- Mobile: hamburger + title -->
    <div class="flex items-center justify-between md:hidden py-3">
      <a href="/" class="text-sm font-bold text-text">Onions Without Tears</a>
      <button
        id="menu-toggle"
        class="text-text-muted p-1"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu (hidden by default) -->
    <div id="mobile-menu" class="hidden md:hidden pb-3">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'block py-2 px-2 text-sm rounded transition-colors',
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-onion font-semibold bg-cream'
              : 'text-text-muted hover:text-onion',
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center justify-center gap-1 py-3">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-1.5 text-sm rounded-full transition-colors',
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-onion font-semibold bg-cream'
              : 'text-text-muted hover:text-onion hover:bg-cream/50',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
