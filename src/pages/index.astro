---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import frontCover from '../assets/front-cover.jpeg';
import backCover from '../assets/back-cover.jpeg';
---

<Layout title="Onions Without Tears by Alison Bessborough" description="A practical handbook of cooking tips gathered over a lifetime, by Alison Bessborough, Countess of Bessborough. Available for £9.50 at The Stansted Park Farm Shop or direct from the author.">

  <!-- Hero -->
  <section class="bg-white">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-24 text-center">

      <!-- Both covers side by side -->
      <div class="flex justify-center gap-6 md:gap-10 items-center mb-10">
        <div class="w-[180px] md:w-[228px] bg-cream-dark border-2 border-warm-light rounded-lg shadow-lg overflow-hidden">
          <Image
            src={frontCover}
            alt="Front cover illustration: a chef contentedly smelling a red onion"
            class="w-full h-auto"
            widths={[180, 228]}
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="w-[180px] md:w-[228px] bg-cream-dark border-2 border-warm-light rounded-lg shadow-lg overflow-hidden">
          <Image
            src={backCover}
            alt="Back cover illustration: the same chef crying from the onion"
            class="w-full h-auto"
            widths={[180, 228]}
            loading="eager"
          />
        </div>
      </div>

      <h1 class="text-5xl md:text-5xl lg:text-6xl font-bold text-text tracking-tight mb-4 uppercase" style="font-family: 'Bernard MT Condensed', 'BernardMT-Condensed', 'EB Garamond', Georgia, serif;">
        Onions Without Tears
      </h1>
      <p class="text-lg md:text-xl text-text-muted mb-2">
        A handbook of cooking tips
      </p>
      <p class="text-base md:text-lg text-text-muted italic">
        by Alison Bessborough
      </p>

      <div class="mt-8">
        <span class="text-2xl font-bold text-onion">£9.50</span>
      </div>
      <p class="mt-4 text-base text-text-muted">
        <a href="#find" class="text-onion hover:text-onion-dark underline decoration-onion/40 hover:decoration-onion transition-colors">Find out where to get a copy</a>
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="h-1 bg-gradient-to-r from-cream via-onion/20 to-cream" aria-hidden="true"></div>

  <!-- Introduction -->
  <section class="bg-cream" id="introduction">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-20">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Introduction</h2>
      <p class="mb-6">
        This collection is all about tips I have gathered over the years
        from family, friends, publications, odd errors I have made and
        some experiments. I hope some of these prove useful for any
        cook, be they experienced or not.
      </p>
      <p class="mb-6">
        I have included cooking methods and terms in case you are not familiar
        with them, as so often you come across them in cookbooks. This is not
        a recipe book, although I have added the odd unusual recipe which one
        wouldn't normally come across.
      </p>
      <p class="scroll-animate">
        I have found that keeping a notebook or a digital record with an
        index of recipes that I have served up, with the name of the
        cookbook and page number, has proved a useful aide memoire.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="h-1 bg-gradient-to-r from-cream via-onion/20 to-cream" aria-hidden="true"></div>

  <!-- Acknowledgements -->
  <section class="bg-white">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-20">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-center">Acknowledgements</h2>
      <p class="text-text-muted text-center mb-10">This book wouldn't exist without the help and encouragement of some great people.</p>
      <ul class="space-y-3 max-w-xl mx-auto bg-cream border border-border rounded-xl p-6 md:p-8">
        <li class="flex gap-3">
          <span class="text-onion mt-1">•</span>
          <span><span class="relative group cursor-pointer"><span class="text-onion underline decoration-onion/40">Sally Somers</span><span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1.5 bg-text text-white text-xs rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">Link coming soon</span></span> for editing the text and suggesting improvements with patience and expertise.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-onion mt-1">•</span>
          <span>Marcus &amp; Grania Gregson and Claudia &amp; Michael Langdon for their recipe suggestions and gentle persistence in encouraging me to finish.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-onion mt-1">•</span>
          <span>Emily Duncannon for proofreading.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-onion mt-1">•</span>
          <span><a href="/farm-shop/" class="text-onion hover:text-onion-dark underline decoration-onion/40 hover:decoration-onion transition-colors">Fred Duncannon</a> for the layout, managing the printing, and his invaluable IT support.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-onion mt-1">•</span>
          <span><a href="/illustrations/" class="text-onion hover:text-onion-dark underline decoration-onion/40 hover:decoration-onion transition-colors">Chris Gilbert</a> for his brilliant and hilarious illustrations.</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Where to Find It -->
  <section class="bg-white" id="find">
    <div class="max-w-2xl mx-auto px-6 py-16 md:py-20 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">Where to find it</h2>
      <p class="mb-6">
        Onions Without Tears is available at Fred Duncannon's
        <a
          href="https://stanstedfarmshop.com/contact-us/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-onion hover:text-onion-dark underline decoration-onion/40 hover:decoration-onion transition-colors"
        >Stansted Park Farm Shop</a>.
      </p>
      <p class="mb-8">
        You can also <a href="/contact/" class="text-onion hover:text-onion-dark underline decoration-onion/40 hover:decoration-onion transition-colors">get in touch</a> to enquire about ordering a copy directly.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="https://stanstedfarmshop.com/contact-us/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center bg-onion hover:bg-onion-dark text-white font-semibold px-8 py-3 rounded-full transition-colors"
        >
          Visit the Farm Shop
        </a>
        <a
          href="/contact/"
          class="flex items-center justify-center border-2 border-onion text-onion hover:bg-onion-dark hover:border-onion-dark hover:text-white font-semibold px-8 py-3 rounded-full transition-colors"
        >
          Order direct
        </a>
      </div>
    </div>
  </section>

  <Footer />

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Book",
  "name": "Onions Without Tears",
  "author": {
    "@type": "Person",
    "name": "Alison Bessborough",
    "honorificPrefix": "Countess of Bessborough"
  },
  "description": "A practical handbook of cooking tips gathered over a lifetime.",
  "offers": {
    "@type": "Offer",
    "price": "9.50",
    "priceCurrency": "GBP",
    "availability": "https://schema.org/InStock"
  },
  "url": "https://onionswithouttears.co.uk"
}
</script>

</Layout>

