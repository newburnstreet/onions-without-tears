---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — Onions Without Tears">

  <section class="bg-white">
    <div class="max-w-xl mx-auto px-6 py-16 md:py-20">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-center">Get in touch</h1>
      <p class="text-text-muted text-center mb-10">
        Whether you'd like to order a copy of the book, ask a question,
        or simply say hello — drop a message below.
      </p>

      <form id="contact-form" class="space-y-6" method="POST" action="#contact">
        <!-- Honeypot field — hidden from humans, catches bots -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="website">Website</label>
          <input
            type="text"
            id="website"
            name="website"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <div>
          <label for="name" class="block text-sm font-semibold mb-2">Your name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-lg border border-border bg-cream focus:outline-none focus:ring-2 focus:ring-onion/30 focus:border-onion transition-colors"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold mb-2">Email address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-lg border border-border bg-cream focus:outline-none focus:ring-2 focus:ring-onion/30 focus:border-onion transition-colors"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full px-4 py-3 rounded-lg border border-border bg-cream focus:outline-none focus:ring-2 focus:ring-onion/30 focus:border-onion transition-colors resize-y"
            placeholder="I'd love a copy of the book…"
          ></textarea>
        </div>

        <div class="text-center">
          <button
            type="submit"
            class="bg-onion hover:bg-onion-dark text-white font-semibold px-8 py-3 rounded-full transition-colors cursor-pointer"
          >
            Send message
          </button>
        </div>
      </form>

      <!-- Success message (hidden by default) -->
      <div id="form-success" class="hidden text-center py-8">
        <p class="text-lg font-semibold text-onion-dark mb-2">Thank you!</p>
        <p class="text-text-muted">Your message has been sent. Ali will be in touch soon.</p>
      </div>

      <p class="text-xs text-text-muted text-center mt-8">
        Your details won't be shared with anyone. This form simply sends an email.
      </p>
    </div>
  </section>

  <Footer />

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success') as HTMLElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const honeypot = form.querySelector<HTMLInputElement>('input[name="website"]');
    if (honeypot?.value) return;
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
