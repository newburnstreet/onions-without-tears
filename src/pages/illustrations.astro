---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

// Import all chapter illustrations
import ovenTemps from '../assets/illustrations/oven-temporatures.jpeg';
import kitchenLayout from '../assets/illustrations/kitchen-layout.jpg';
import kitchenEssentials from '../assets/illustrations/kitchen-essentials-gadgets.jpeg';
import storeCupboard from '../assets/illustrations/store-cupboard.jpeg';
import herbsSpices from '../assets/illustrations/herbs-spices.jpeg';
import cookingTerms from '../assets/illustrations/cooking-terms-methods.jpeg';
import stocks from '../assets/illustrations/stocks.jpeg';
import sauces from '../assets/illustrations/sauces.jpeg';
import soups from '../assets/illustrations/soups.jpeg';
import eggsDairy from '../assets/illustrations/eggs-dairy.jpeg';
import fish from '../assets/illustrations/fish.jpeg';
import meat from '../assets/illustrations/meat.jpeg';
import poultryGame from '../assets/illustrations/poultry-game.jpeg';
import vegatables from '../assets/illustrations/vegatables.jpeg';
import pastaRice from '../assets/illustrations/pasta-rice.jpeg';
import fruit from '../assets/illustrations/fruit.jpeg';
import bakingDesserts from '../assets/illustrations/baking-desserts.jpeg';
import freezingPreserving from '../assets/illustrations/freezing-preserving.jpeg';
import notes1 from '../assets/illustrations/notes-1.jpeg';
import notes2 from '../assets/illustrations/notes-2.jpeg';
import notes3 from '../assets/illustrations/notes-3.jpeg';

const illustrations = [
  { src: ovenTemps, label: 'Oven Temperatures' },
  { src: kitchenLayout, label: 'Kitchen Layout', tall: true },
  { src: kitchenEssentials, label: 'Kitchen Essentials & Gadgets' },
  { src: storeCupboard, label: 'Store Cupboard' },
  { src: herbsSpices, label: 'Herbs & Spices' },
  { src: cookingTerms, label: 'Cooking Terms & Methods' },
  { src: stocks, label: 'Stocks' },
  { src: sauces, label: 'Sauces' },
  { src: soups, label: 'Soups' },
  { src: eggsDairy, label: 'Eggs & Dairy' },
  { src: fish, label: 'Fish' },
  { src: meat, label: 'Meat' },
  { src: poultryGame, label: 'Poultry & Game' },
  { src: vegatables, label: 'Vegetables' },
  { src: pastaRice, label: 'Pasta & Rice' },
  { src: fruit, label: 'Fruit' },
  { src: bakingDesserts, label: 'Baking & Desserts' },
  { src: freezingPreserving, label: 'Freezing & Preserving' },
];
---

<Layout title="Illustrations: Onions Without Tears" description="Original drawings by artist Chris Gilbert, created for every chapter of Onions Without Tears, including the front and back covers.">

  <section class="bg-white">
    <div class="max-w-4xl mx-auto px-6 pt-16 md:pt-24 pb-16 md:pb-24">

      <!-- Heading -->
      <h1 class="text-3xl md:text-4xl font-bold mb-1 text-center">Chris Gilbert</h1>
      <p class="text-base text-center text-text-muted mb-8">Artist</p>

      <!-- Thanks to Chris -->
      <div class="bg-cream rounded-xl p-8 md:p-10 border border-border max-w-2xl mx-auto mb-24">
        <p class="text-base text-text-muted mb-6">
          All of the artwork in the book are originals. Chris' drawings are hilarious and I am hugely grateful for his contribution.
        </p>
        <p class="text-base text-text-muted mb-12">
          He is a very talented artist whose work spans etchings, humour, pastels, sketches
          and woodcuts. You can explore his portfolio via the links below on theartistsweb.co.uk:
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="https://chrisgilbert.theartistsweb.co.uk/chrisgilbert.theartistsweb.co.uk" target="_blank" rel="noopener noreferrer"
            class="px-4 py-1.5 text-sm border border-onion text-onion rounded-full hover:bg-onion-dark hover:border-onion-dark hover:text-white transition-colors">
            Etchings
          </a>
          <a href="https://chrisgilbert.theartistsweb.co.uk/humour" target="_blank" rel="noopener noreferrer"
            class="px-4 py-1.5 text-sm border border-onion text-onion rounded-full hover:bg-onion-dark hover:border-onion-dark hover:text-white transition-colors">
            Humour
          </a>
          <a href="https://chrisgilbert.theartistsweb.co.uk/pastel-paintings" target="_blank" rel="noopener noreferrer"
            class="px-4 py-1.5 text-sm border border-onion text-onion rounded-full hover:bg-onion-dark hover:border-onion-dark hover:text-white transition-colors">
            Pastels
          </a>
          <a href="https://chrisgilbert.theartistsweb.co.uk/sketches" target="_blank" rel="noopener noreferrer"
            class="px-4 py-1.5 text-sm border border-onion text-onion rounded-full hover:bg-onion-dark hover:border-onion-dark hover:text-white transition-colors">
            Sketches
          </a>
          <a href="https://chrisgilbert.theartistsweb.co.uk/woodcuts-chrisgilbert.theartistsweb.co.uk" target="_blank" rel="noopener noreferrer"
            class="px-4 py-1.5 text-sm border border-onion text-onion rounded-full hover:bg-onion-dark hover:border-onion-dark hover:text-white transition-colors">
            Woodcuts
          </a>
        </div>
      </div>

      <!-- Chapter illustrations -->
      <h2 class="text-2xl md:text-3xl font-bold mb-6 md:mb-8 text-center">Chapter Illustrations</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-6 md:gap-x-8 gap-y-12 sm:gap-y-16 md:gap-y-20">
        {illustrations.map(({ src, label, tall }) => (
          <div class="text-center">
            <p class="text-sm text-text mb-2">{label}</p>
            <div class:list={['border-2 border-warm-light rounded-lg shadow-lg overflow-hidden', tall ? 'aspect-square p-3 bg-white' : 'bg-cream-dark']}>
              <Image
                src={src}
                alt={`Illustration for ${label} chapter`}
                class={tall ? 'w-full h-full object-contain' : 'w-full h-auto'}
                widths={[300, 400]}
              />
            </div>
          </div>
        ))}
      </div>

      <!-- Notes illustrations (hidden — uncomment to reinstate)
      <h2 class="text-2xl md:text-3xl font-bold mt-24 mb-16 text-center">Notes Illustrations</h2>
      <div class="flex flex-col items-center gap-6 md:gap-8">
        <div class="flex justify-center gap-6 md:gap-8 w-full">
          <div class="border-2 border-warm-light rounded-lg shadow-lg overflow-hidden aspect-square p-3 bg-white w-full max-w-[calc(33.333%-0.75rem)]">
            <Image src={notes3} alt="Notes illustration 3" class="w-full h-full object-contain" widths={[300, 400]} />
          </div>
          <div class="border-2 border-warm-light rounded-lg shadow-lg overflow-hidden aspect-square p-3 bg-white w-full max-w-[calc(33.333%-0.75rem)]">
            <Image src={notes2} alt="Notes illustration 2" class="w-full h-full object-contain" widths={[300, 400]} />
          </div>
        </div>
        <div class="border-2 border-warm-light rounded-lg shadow-lg overflow-hidden p-3 bg-white w-full max-w-[calc(66.666%-0.375rem)]" style="aspect-ratio: 2/1">
          <Image src={notes1} alt="Notes illustration 1" class="w-full h-full object-contain" widths={[600, 900]} />
        </div>
      </div>
      -->

    </div>
  </section>

  <Footer />

</Layout>
